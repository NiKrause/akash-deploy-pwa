# Create-deployment escrow + SDL placement pricing (ACT / uact on current sandbox/mainnet). Override only for legacy nodes.
# VITE_DEPLOYMENT_ESCROW_DENOM=uact
# VITE_DEPLOYMENT_ESCROW_COIN_DENOM=ACT

# Optional Akash provider API proxy. Use this when browser CORS blocks provider manifest/status calls.
# Deploy workers/provider-proxy.js somewhere you trust, then set its URL here.
# The wallet-signed provider JWT passes through this proxy, so do not use an untrusted deployment.
# VITE_PROVIDER_PROXY_URL=https://akash-provider-proxy.example.workers.dev/

# Sandbox (defaults match chain-sdk + public sandbox if unset)
# VITE_SANDBOX_CHAIN_ID=sandbox-2
# VITE_SANDBOX_RPC=https://rpc.sandbox-2.aksh.pw:443
# gRPC-gateway base (not rest.* — that hostname does not resolve)
# VITE_SANDBOX_REST=https://api.sandbox-2.aksh.pw:443
# Chain explorer (official sandbox explorer from akash-network/net)
# VITE_SANDBOX_EXPLORER_HOME=https://explorer.sandbox-2.aksh.pw/akash
# VITE_SANDBOX_EXPLORER_ACCOUNT=https://explorer.sandbox-2.aksh.pw/akash/account/${accountAddress}
# VITE_SANDBOX_EXPLORER_TX=https://explorer.sandbox-2.aksh.pw/akash/tx/${txHash}
# VITE_SANDBOX_EXPLORER_LABEL=Sandbox explorer

# Mainnet (defaults: PublicNode — see Cosmos chain-registry akash/chain.json)
# VITE_MAINNET_CHAIN_ID=akashnet-2
# VITE_MAINNET_RPC=https://akash-rpc.publicnode.com:443
# VITE_MAINNET_REST=https://akash-rest.publicnode.com
# VITE_MAINNET_EXPLORER_HOME=https://www.mintscan.io/akash
# VITE_MAINNET_EXPLORER_ACCOUNT=https://www.mintscan.io/akash/accounts/${accountAddress}
# VITE_MAINNET_EXPLORER_TX=https://www.mintscan.io/akash/tx/${txHash}
# VITE_MAINNET_EXPLORER_LABEL=Mintscan

# BME testnet (defaults: akash-network/net `testnet-oracle` — public LCD/RPC; legacy `testnet-8` *testnet{api,rpc}.akashnet.net* is not anonymously accessible)
# VITE_TESTNET_CHAIN_ID=testnet-oracle
# VITE_TESTNET_RPC=https://testnetoraclerpc.akashnet.net:443
# VITE_TESTNET_REST=https://testnetoracleapi.akashnet.net
# VITE_TESTNET_EXPLORER_HOME=https://github.com/akash-network/net/tree/main/testnet-oracle
# VITE_TESTNET_EXPLORER_ACCOUNT=
# VITE_TESTNET_EXPLORER_TX=
# VITE_TESTNET_EXPLORER_LABEL=Testnet config (GitHub)
# Gas faucet URLs: `net` still lists oraclefaucet.dev.akash.pub (often unreachable). App defaults to faucet.dev.akash.pub first.
# VITE_TESTNET_FAUCET_URL=https://faucet.dev.akash.pub/
# VITE_TESTNET_FAUCET_ALT_URL=https://oraclefaucet.dev.akash.pub/
# Comma-separated list replaces primary+alternate entirely:
# VITE_TESTNET_FAUCET_URLS=https://faucet.dev.akash.pub/,https://oraclefaucet.dev.akash.pub/
